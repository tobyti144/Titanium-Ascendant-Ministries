nded-full hover:bg-blue-700\"\u003e\u003ci class\u003d\"fas fa-eye\"\u003e\u003c/i\u003e\u003c/button\u003e\n                    \u003c/div\u003e\n                \u003c/div\u003e\n                \u003cdiv class\u003d\"p-3\"\u003e\n                    \u003cp class\u003d\"text-xs font-medium text-gray-900 truncate\"\u003eAsset_4272.jpg\u003c/p\u003e\n                    \u003cp class\u003d\"text-[10px] text-gray-500\"\u003eImage / JPEG\u003c/p\u003e\n                \u003c/div\u003e\n            \u003c/div\u003e\n\n            \u003c!-- Media Item 2 --\u003e\n            \u003cdiv class\u003d\"bg-white rounded-lg border border-gray-200 shadow-sm archive-card overflow-hidden group\"\u003e\n                \u003cdiv class\u003d\"aspect-w-1 aspect-h-1 bg-gray-200 relative flex items-center justify-center h-40\"\u003e\n                    \u003ci class\u003d\"fas fa-image text-gray-400 text-3xl\"\u003e\u003c/i\u003e\n                    \u003cdiv class\u003d\"absolute inset-0 bg-black bg-opacity-0 group-hover:bg-opacity-40 transition flex items-center justify-center opacity-0 group-hover:opacity-100\"\u003e\n                        \u003cbutton class\u003d\"text-white bg-blue-600 p-2 rounded-full hover:bg-blue-700\"\u003e\u003ci class\u003d\"fas fa-eye\"\u003e\u003c/i\u003e\u003c/button\u003e\n                    \u003c/div\u003e\n                \u003c/div\u003e\n                \u003cdiv class\u003d\"p-3\"\u003e\n                    \u003cp class\u003d\"text-xs font-medium text-gray-900 truncate\"\u003eAsset_2228.png\u003c/p\u003e\n                    \u003cp class\u003d\"text-[10px] text-gray-500\"\u003eImage / PNG\u003c/p\u003e\n                \u003c/div\u003e\n            \u003c/div\u003e\n            \n            \u003c!-- Media Item 3 --\u003e\n            \u003cdiv class\u003d\"bg-white rounded-lg border border-gray-200 shadow-sm archive-card overflow-hidden group\"\u003e\n                \u003cdiv class\u003d\"aspect-w-1 aspect-h-1 bg-gray-200 relative flex items-center justify-center h-40\"\u003e\n                    \u003ci class\u003d\"fas fa-image text-gray-400 text-3xl\"\u003e\u003c/i\u003e\n                    \u003cdiv class\u003d\"absolute inset-0 bg-black bg-opacity-0 group-hover:bg-opacity-40 transition flex items-center justify-center opacity-0 group-hover:opacity-100\"\u003e\n                        \u003cbutton class\u003d\"text-white bg-blue-600 p-2 rounded-full hover:bg-blue-700\"\u003e\u003ci class\u003d\"fas fa-eye\"\u003e\u003c/i\u003e\u003c/button\u003e\n                    \u003c/div\u003e\n                \u003c/div\u003e\n                \u003cdiv class\u003d\"p-3\"\u003e\n                    \u003cp class\u003d\"text-xs font-medium text-gray-900 truncate\"\u003eAsset_5379.jpg\u003c/p\u003e\n                    \u003cp class\u003d\"text-[10px] text-gray-500\"\u003eImage / JPEG\u003c/p\u003e\n                \u003c/div\u003e\n            \u003c/div\u003e\n\n        \u003c/div\u003e\n    \u003c/div\u003e\n\n    \u003c!-- Tab Content: Data --\u003e\n    \u003cdiv id\u003d\"tab-data\" class\u003d\"tab-content\"\u003e\n        \u003cdiv class\u003d\"bg-white rounded-lg border border-gray-200 shadow-sm overflow-hidden\"\u003e\n            \u003ctable class\u003d\"min-w-full divide-y divide-gray-200\"\u003e\n                \u003cthead class\u003d\"bg-gray-50\"\u003e\n                    \u003ctr\u003e\n                        \u003cth scope\u003d\"col\" class\u003d\"px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider\"\u003eFile Name\u003c/th\u003e\n                        \u003cth scope\u003d\"col\" class\u003d\"px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider\"\u003eType\u003c/th\u003e\n                        \u003cth scope\u003d\"col\" class\u003d\"px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider\"\u003eDate Logged\u003c/th\u003e\n                        \u003cth scope\u003d\"col\" class\u003d\"relative px-6 py-3\"\u003e\u003cspan class\u003d\"sr-only\"\u003eAction\u003c/span\u003e\u003c/th\u003e\n                    \u003c/tr\u003e\n                \u003c/thead\u003e\n                \u003ctbody class\u003d\"bg-white divide-y divide-gray-200\"\u003e\n                    \u003ctr\u003e\n                        \u003ctd class\u003d\"px-6 py-4 whitespace-nowrap\"\u003e\n                            \u003cdiv class\u003d\"flex items-center\"\u003e\n                                \u003ci class\u003d\"fab fa-facebook text-blue-600 mr-3 text-lg\"\u003e\u003c/i\u003e\n                                \u003cdiv class\u003d\"text-sm font-medium text-gray-900\"\u003eFacebook_Export_Data_1\u003c/div\u003e\n                            \u003c/div\u003e\n                        \u003c/td\u003e\n                        \u003ctd class\u003d\"px-6 py-4 whitespace-nowrap text-sm text-gray-500\"\u003eapplication/octet-stream\u003c/td\u003e\n                        \u003ctd class\u003d\"px-6 py-4 whitespace-nowrap text-sm text-gray-500\"\u003eMarch 2, 2026\u003c/td\u003e\n                        \u003ctd class\u003d\"px-6 py-4 whitespace-nowrap text-right text-sm font-medium\"\u003e\n                            \u003ca href\u003d\"#\" class\u003d\"text-blue-600 hover:text-blue-900\"\u003eView\u003c/a\u003e\n                        \u003c/td\u003e\n                    \u003c/tr\u003e\n                    \u003ctr\u003e\n                        \u003ctd class\u003d\"px-6 py-4 whitespace-nowrap\"\u003e\n                            \u003cdiv class\u003d\"flex items-center\"\u003e\n                                \u003ci class\u003d\"fab fa-facebook text-blue-600 mr-3 text-lg\"\u003e\u003c/i\u003e\n                                \u003cdiv class\u003d\"text-sm font-medium text-gray-900\"\u003eFacebook_Export_Data_2\u003c/div\u003e\n                            \u003c/div\u003e\n                        \u003c/td\u003e\n                        \u003ctd class\u003d\"px-6 py-4 whitespace-nowrap text-sm text-gray-500\"\u003eapplication/octet-stream\u003c/td\u003e\n                        \u003ctd class\u003d\"px-6 py-4 whitespace-nowrap text-sm text-gray-500\"\u003eMarch 2, 2026\u003c/td\u003e\n                        \u003ctd class\u003d\"px-6 py-4 whitespace-nowrap text-right text-sm font-medium\"\u003e\n                            \u003ca href\u003d\"#\" class\u003d\"text-blue-600 hover:text-blue-900\"\u003eView\u003c/a\u003e\n                        \u003c/td\u003e\n                    \u003c/tr\u003e\n                \u003c/tbody\u003e\n            \u003c/table\u003e\n        \u003c/div\u003e\n    \u003c/div\u003e\n\n\u003c/main\u003e\n\n\u003cscript\u003e\n    function openTab(tabName) {\n        // Hide all tab contents\n        const contents \u003d document.querySelectorAll(\u0027.tab-content\u0027);\n        contents.forEach(content \u003d\u003e {\n            content.classList.remove(\u0027active\u0027);\n        });\n\n        // Remove active state from all buttons\n        const buttons \u003d document.querySelectorAll(\u0027.tab-btn\u0027);\n        buttons.forEach(button \u003d\u003e {\n            button.classList.remove(\u0027active\u0027);\n            button.classList.remove(\u0027text-blue-600\u0027);\n            button.classList.remove(\u0027border-blue-500\u0027);\n            button.classList.add(\u0027border-transparent\u0027);\n            button.classList.add(\u0027text-gray-500\u0027);\n        });\n\n        // Show selected tab content\n        document.getElementById(\u0027tab-\u0027 + tabName).classList.add(\u0027active\u0027);\n\n        // Add active state to clicked button\n        const activeBtn \u003d document.getElementById(\u0027btn-\u0027 + tabName);\n        activeBtn.classList.add(\u0027active\u0027);\n        activeBtn.classList.remove(\u0027border-transparent\u0027);\n        activeBtn.classList.remove(\u0027text-gray-500\u0027);\n    }\n\u003c/script\u003e",
